{
  "permissions": {
    "allow": [
      "Bash(node .claude/scripts/milestone-dag.mjs:*)",
      "Bash(node .claude/scripts/publish-tickets.mjs:*)",
      "Bash(node .claude/scripts/deliver-ticket.mjs:*)",
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(git checkout:*)",
      "Bash(git switch:*)",
      "Bash(git restore:*)",
      "Bash(git add:*)",
      "Bash(git rm:*)",
      "Bash(git mv:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(git fetch:*)",
      "Bash(git pull:*)",
      "Bash(git stash:*)",
      "Bash(git rev-parse:*)",
      "Bash(git remote get-url:*)",
      "Bash(git merge-base:*)",
      "Bash(npm test:*)",
      "Bash(npm run test:*)",
      "Bash(node --test:*)",
      "Bash(gh auth status)",
      "Bash(gh issue list:*)",
      "Bash(gh issue view:*)",
      "Bash(gh issue comment:*)",
      "Bash(gh issue edit:*)",
      "Bash(gh issue close:*)",
      "Bash(gh issue create:*)",
      "Bash(glab auth status)",
      "Bash(glab issue list:*)",
      "Bash(glab issue view:*)",
      "Bash(glab issue note:*)",
      "Bash(glab issue update:*)",
      "Bash(glab issue close:*)",
      "Bash(glab issue create:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/guard-main-session-writes.mjs"
          }
        ]
      }
    ]
  }
}
